# Copie este arquivo para .streamlit/secrets.toml e preencha com os valores
# reais. O arquivo .streamlit/secrets.toml NUNCA deve ser commitado no Git
# (já está no .gitignore) - ele é só para uso local.
#
# No Streamlit Community Cloud, você não usa este arquivo: em vez disso,
# cole o mesmo conteúdo (com os valores reais) em "Settings > Secrets" do
# app, depois do deploy.

MOVIDESK_TOKEN = "cole-aqui-o-token-do-movidesk"
SUPABASE_DB_URL = "postgresql://usuario:senha@host:5432/postgres"
